    "ai": "^6.0.190",
    "bcryptjs": "^3.0.3",
    "element-plus": "^2.11.8",
    "nuxt": "^4.2.1",
    "pinia": "^3.0.4",
    "prisma": "^7.8.0",
    "redis": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vue-tsc": "^3.1.5"
  }
