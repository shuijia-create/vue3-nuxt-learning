# 你的线上域名。正式域名写 example.com；临时只用 IP 测试可以写 :80。
APP_DOMAIN=example.com

# MySQL 容器初始化信息。
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=nuxt_admin_learning
MYSQL_USER=nuxt_app
MYSQL_PASSWORD=change-this-app-password

# Nuxt 后端访问 Docker Compose 内部 MySQL/Redis 的地址。
DATABASE_URL=mysql://nuxt_app:change-this-app-password@mysql:3306/nuxt_admin_learning
REDIS_URL=redis://redis:6379

# AI 工单草稿和知识库问答配置。
NUXT_AI_API_KEY=change-this-ai-api-key
NUXT_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NUXT_AI_MODEL=qwen-plus

# Nitro Node 服务监听配置。
HOST=0.0.0.0
PORT=3000
