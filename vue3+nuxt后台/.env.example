NUXT_AI_API_KEY=
NUXT_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NUXT_AI_MODEL=qwen-plus

# Prisma 连接 MySQL 的模板地址，真实密码只写在本地 .env。
# 格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://root:password@localhost:3306/nuxt_admin_learning"

# 登录 token 保存位置。
# memory：学习默认值，token 存在 Nuxt 服务内存里，服务重启后登录态丢失。
# redis：真实项目常用方式，token 存到 Redis，服务重启后仍可通过 Redis 找回。
SESSION_STORE=memory

# SESSION_STORE=redis 时使用这个地址连接 Redis。
# 本地 Redis 默认端口是 6379。
REDIS_URL="redis://localhost:6379"
