NUXT_AI_API_KEY=
NUXT_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NUXT_AI_MODEL=qwen-plus

# 登录密码传输加密使用 RSA-OAEP。
# 本地学习可以不配置，服务端会自动生成内存密钥对。
# 生产环境应配置固定密钥；多行 PEM 可以把换行写成 \n。
PASSWORD_PUBLIC_KEY=
PASSWORD_PRIVATE_KEY=

# Prisma 连接 MySQL 的模板地址，真实密码只写在本地 .env。
# 格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://root:password@localhost:3306/nuxt_admin_learning"

# 登录 token 统一保存到 Redis。
# 本地 Redis 默认端口是 6379；没写 REDIS_URL 时，代码也会默认使用这个地址。
REDIS_URL="redis://localhost:6379"

# Docker 启动或复用 Redis 容器：
# npm run redis:up
#
# 当前 Nuxt 项目运行在宿主机，所以连接 localhost。
# 如果以后把 Nuxt 也放进同一个 Docker 网络，才改成容器网络里的 Redis 地址。
